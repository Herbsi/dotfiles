[battery]
full_symbol = "• "
charging_symbol = "⇡ "
discharging_symbol = "⇣ "
unknown_symbol = "❓ "
empty_symbol = "❗ "

[erlang]
symbol = "ⓔ "

[nodejs]
symbol = "[⬢](bold green) "

[pulumi]
symbol = "🧊 "

[typst]
symbol = "t "

[custom.jj]
ignore_timeout = true
description = "The current jj status"
when = true
command = 'jj log -r @ --no-graph --color always -T prompt && jj op log -T "id.short(4)" --limit 1 --no-graph --color always --ignore-working-copy'

[custom.jjstate]
when = "jj root"
{{- if eq .chezmoi.hostname "SLCH-GM0G33YJ" }}
command = '''
jj log -r@ -n1 --no-graph -T "" --stat |
  Get-Content -Tail 1 |
  sd "(\\d+) files? changed, (\\d+) insertions?\\(\\+\\), (\\d+) deletions?\\(-\\)" ' ${1}m ${2}+ ${3}-' |
  sd " 0\." ""
'''
{{- end }}
{{- if ne .chezmoi.hostname "SLCH-GM0G33YJ" }}
command = '''
jj log -r@ -n1 --no-graph -T "" --stat | tail -n1 | sd "(\d+) files? changed, (\d+) insertions?\(\+\), (\d+) deletions?\(-\)" ' ${1}m ${2}+ ${3}-' | sd " 0." ""
'''
{{- end }}
